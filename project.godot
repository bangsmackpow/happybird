; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via text if you know what you're doing.

config_version=5

[application]

config/name="Flappy Family"
run/main_scene="res://scenes/Game.tscn"
config/features=PackedStringArray("4.2", "Mobile")

[autoload]

PlayerManager="*res://scripts/player_manager.gd"
SoundManager="*res://scripts/sound_manager.gd"

[display]

window/size/viewport_width=540
window/size/viewport_height=960
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation=1
window/stretch/scale_mode="integer"

[input]

flap={
"deadzone": 0.5,
"events": [Object(InputEventScreenTouch,"resource_local_to_scene":false,"resource_name":"","device":0,"window_id":0,"index":0,"pressed":false,"position":Vector2(0, 0),"position_relative":Vector2(0, 0),"velocity":Vector2(0, 0),"double_tap":false,"canceled":false,)
]
}

[rendering]

renderer/rendering_method="mobile"
textures/canvas_textures/default_texture_filter=0
quality/filters/use_nearest_mipmap_filter=0
